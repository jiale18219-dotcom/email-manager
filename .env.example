PORT=3001
# Optional: DATABASE_URL takes priority when provided.
# DATABASE_URL=postgresql://litellm:your-password@127.0.0.1:5432/litellm

# Optional fallback fields when DATABASE_URL is not set.
PGHOST=127.0.0.1
PGPORT=5432
